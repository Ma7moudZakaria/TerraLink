{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LoggingOptions": {
    "ServiceName": "TerraLink",
    "MinimumLogLevel": "Warning",
    "WriteToFile": true,
    "ConsoleLogging": {
      "UseCompactJson": false,
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
      "Theme": "literate"
    },
    "FileLogging": {
      "LogDirectory": "Logs",
      "LogFileName": "log.txt",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 15,
      "SharedFile": false,
      "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} | {Level:u3} | {SourceContext} | {Message:l}{NewLine}{Properties}{NewLine}{Exception}"
    },
    "ExceptionHandling": {
      "MaxDestructuringDepth": 3
    },
    "RequestEnrichment": {
      "IncludeQueryString": false,
      "IncludeAuthenticatedUser": false,
      "IncludeUserRoles": false,
      "IncludeUserAgent": true,
      "IncludeReferer": false,
      "AllowedQueryKeys": []
    },
    "ForwardedHeaders": {
      "Enabled": true,
      "KnownProxies": [],
      "KnownNetworks": [],
      "ForwardLimit": 1,
      "RequireHeaderSymmetry": true
    },
    "SelfLog": {
      "Enabled": false,
      "WriteToConsoleError": true,
      "FilePath": null
    }
  },
  "TelemetryOptions": {
    "Enabled": false,
    "ConnectionString": null
  },
  "AllowedOrigins": [
    "http://localhost:4200"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TerraLinkDB;Integrated Security=true;TrustServerCertificate=true"
  },
  "IdentityShield": {
    "Jwt": {
      "Secret": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE",
      "Issuer": "TerraLink",
      "Audience": "TerraLinkAPI",
      "AccessTokenExpirationMinutes": 30,
      "RefreshTokenExpirationDays": 7,
      "OTPExpirationMinutes": 10
    },
    "Password": {
      "HasherKey": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE",
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequireUppercase": true,
      "RequireNonAlphanumeric": false,
      "RequiredLength": 6,
      "RequiredUniqueChars": 1
    },
    "Lockout": {
      "Enabled": true,
      "AllowedForNewUsers": true,
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpanMinutes": 15
    },
    "Session": {
      "EnableSingleSession": false,
      "TrackConcurrentSessions": true,
      "MaxConcurrentSessions": 0
    },
    "User": {
      "RequireUniqueEmail": false,
      "RequireConfirmedEmail": false,
      "RequireConfirmedPhoneNumber": false
    }
  }
}
